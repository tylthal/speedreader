{
  "name": "speedreader",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node -e \"const{execSync}=require('child_process');execSync('uvicorn backend.main:app --host 0.0.0.0 --port 3000',{stdio:'inherit'})\"",
    "dev:all": "bash scripts/dev.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.0",
    "react-window": "^1.8.11",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "~5.8.3",
    "vite": "^6.3.1",
    "vite-plugin-pwa": "^1.0.0"
  }
}
